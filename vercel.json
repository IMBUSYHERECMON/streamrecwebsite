{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd streamrecwebsite-main && npm install",
  "buildCommand": "cd streamrecwebsite-main && npm run build",
  "outputDirectory": "streamrecwebsite-main/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/api/index.ts" }
  ]
}

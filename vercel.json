{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd streamrecwebsite-main && npm install && python3 -m venv .venv && .venv/bin/pip install streamlink",
  "buildCommand": "cd streamrecwebsite-main && npm run build",
  "outputDirectory": "streamrecwebsite-main/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": [
        "streamrecwebsite-main/.venv/**",
        "streamrecwebsite-main/node_modules/youtube-dl-exec/bin/**",
        "streamrecwebsite-main/node_modules/ffmpeg-static/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ]
}
